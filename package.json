{
  "name": "vertical-preflight-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:api\" \"npm:dev:ui\"",
    "dev:api": "tsx watch src/server/index.ts",
    "dev:ui": "vite --host 127.0.0.1",
    "mcp": "tsx src/mcp/server.ts",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "lint": "tsc --noEmit",
    "test": "tsc --noEmit"
  },
  "dependencies": {
    "@langchain/langgraph": "^0.2.74",
    "@modelcontextprotocol/sdk": "^1.13.1",
    "concurrently": "^9.1.2",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^5.4.11",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
